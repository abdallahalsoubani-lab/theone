{
  "name": "theone-pt",
  "version": "0.1.0",
  "private": true,
  "description": "Theone.pt — bilingual physiotherapy clinic management web application",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings=0",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "infra:up": "docker compose up -d && bash ./scripts/init-minio.sh",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:reset": "docker compose down -v && docker compose up -d && bash ./scripts/init-minio.sh",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset --force",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "i18n:check": "tsx scripts/check-i18n-sync.ts",
    "workers:start": "dotenv -e .env.local -- tsx workers/index.ts",
    "bootstrap:admin": "NODE_ENV=production tsx scripts/bootstrap-admin.ts",
    "size-limit": "size-limit",
    "prepare": "husky"
  },
  "size-limit": [
    {
      "name": "First-load JS (any single page)",
      "path": ".next/static/chunks/pages/**/*.js",
      "limit": "200 kB",
      "gzip": true
    },
    {
      "name": "First-load JS (App Router shared chunks)",
      "path": ".next/static/chunks/*.js",
      "limit": "200 kB",
      "gzip": true
    }
  ],
  "prisma": {
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/core": "^0.34.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.13",
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-table": "^8.21.3",
    "bullmq": "^5.76.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.469.0",
    "next": "15.1.4",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.12.0",
    "react": "19.0.0",
    "react-big-calendar": "^1.19.4",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.76.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "twilio": "^6.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/eslintrc": "^3.3.5",
    "@size-limit/file": "^12.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.5",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "^19.0.3",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.18.0",
    "eslint-config-next": "15.1.4",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "prisma": "^6.19.3",
    "size-limit": "^12.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{css,md,json,yml,yaml}": [
      "prettier --write"
    ]
  }
}
