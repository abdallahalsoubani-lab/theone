// ═════════════════════════════════════════════════════════════════════════════
//  Core: users, profile, specialties
// ═════════════════════════════════════════════════════════════════════════════

model User {
  id           String       @id @default(cuid())
  email        String?
  phone        String
  role         UserRole
  fullNameEn   String
  fullNameAr   String
  languagePref LanguagePref @default(EN)

  // Auth fields — populated by Prompt 4. Kept on User (not a sibling table) so a
  // single SELECT during login fetches everything the auth layer needs.
  passwordHash        String?
  mustChangePassword  Boolean   @default(false)
  passwordChangedAt   DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // WhatsApp delivery reachability — flipped to false by the outbound queue
  // worker after three retries fail (Prompt 8 §4.12). The Secretary uses the
  // patient profile WhatsApp section (§4.11) to triage; the flag flips back
  // to true automatically on the next successful delivery.
  whatsappReachable         Boolean   @default(true)
  whatsappLastFailureAt     DateTime?
  whatsappLastFailureReason String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  patientProfile PatientProfile?
  specialties    UserSpecialty[]

  // Relations as actor across the domain. Names are explicit because several
  // tables reference User multiple times (e.g. Appointment has patientId, therapistId,
  // createdById) and Prisma needs disambiguation.
  appointmentsAsPatient    Appointment[]          @relation("AppointmentPatient")
  appointmentTherapists    AppointmentTherapist[] @relation("AppointmentTherapistTherapist")
  appointmentsCreatedBy    Appointment[]          @relation("AppointmentCreatedBy")
  treatmentPlansAsPatient  TreatmentPlan[]        @relation("PlanPatient")
  treatmentPlansAsDoctor   TreatmentPlan[]        @relation("PlanDoctor")
  treatmentPlansAsAssigned TreatmentPlan[]        @relation("PlanAssignedTherapist")
  sessionNotesAsPatient    SessionNote[]          @relation("NotePatient")
  sessionNotesAsTherapist  SessionNote[]          @relation("NoteTherapist")
  homeProgramItems         HomeProgramItem[]      @relation("HomeProgramPatient")
  homeProgramApproval      HomeProgramApproval?   @relation("HomeProgramApprovalPatient")
  homeProgramSubmissions   HomeProgramApproval[]  @relation("HomeProgramSubmittedBy")
  homeProgramReviews       HomeProgramApproval[]  @relation("HomeProgramReviewedBy")
  exercisesCreated         Exercise[]             @relation("ExerciseCreatedBy")
  leaves                   Leave[]                @relation("LeaveUser")
  leavesApproved           Leave[]                @relation("LeaveApprovedBy")
  careTeamMemberships      CareTeamMember[]       @relation("CareTeamClinician")
  appointmentsCancelled    Appointment[]          @relation("AppointmentCancelledBy")
  whatsappMessages         WhatsAppMessage[]      @relation("WhatsAppRecipient")
  inboxItems               InboxItem[]            @relation("InboxItemPatient")
  inboxItemsResolved       InboxItem[]            @relation("InboxItemResolvedBy")
  auditLogs                AuditLog[]             @relation("AuditActor")
  auditLogsAsImpersonated  AuditLog[]             @relation("AuditImpersonated")
  intakesAsPatient         IntakeAssessment[]     @relation("IntakePatient")
  intakesAsAssessor        IntakeAssessment[]     @relation("IntakeAssessor")
  intakesAsReviewer        IntakeAssessment[]     @relation("IntakeReviewer")
  customQuestionsCreated   IntakeCustomQuestion[] @relation("CustomQuestionCreatedBy")
  clinicSettingsUpdates    ClinicSettings[]       @relation("ClinicSettingsUpdatedBy")
  notifications            Notification[]         @relation("UserNotifications")
  treatmentPlansApproved   TreatmentPlan[]        @relation("PlanApprovals")
  dayReports               DayReport[]            @relation("TherapistDayReports")
  doctorReviewsAsDoctor    DoctorReview[]         @relation("DoctorReviews")
  doctorReviewsAsPatient   DoctorReview[]         @relation("PatientDoctorReviews")
  waitlistEntriesAsPatient WaitlistEntry[]        @relation("WaitlistPatient")
  waitlistEntriesPreferred WaitlistEntry[]        @relation("WaitlistPreferredTherapist")
  waitlistEntriesCreated   WaitlistEntry[]        @relation("WaitlistCreatedBy")
  waitlistEntriesFulfilled WaitlistEntry[]        @relation("WaitlistFulfilledBy")
  pedAssessmentsAsPatient  PediatricAssessment[]  @relation("PedAssessmentPatient")
  pedAssessmentsCreated    PediatricAssessment[]  @relation("PedAssessmentCreatedBy")
  pedAssessmentsUpdated    PediatricAssessment[]  @relation("PedAssessmentUpdatedBy")
  pedCustomFieldsCreated   PediatricCustomField[] @relation("PedCustomFieldCreatedBy")

  // Note: real `phone` and `email` uniqueness scoped to non-deleted rows is enforced
  // by partial unique indexes in the init migration (Prisma can't express them).
  // These indexes are *also* useful for lookup performance.
  @@index([phone])
  @@index([email])
  @@index([role])
  @@index([deletedAt])
}

model PatientProfile {
  userId String @id
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  dateOfBirth           DateTime
  gender                Gender
  // TODO(Prompt 11 hardening): encrypt at rest via pgcrypto symmetric encryption.
  nationalId            String?
  address               String?
  occupation            String?
  emergencyContactName  String?
  emergencyContactPhone String?
  medicalHistorySummary String?
  allergies             String?
  currentMedications    String?
  hijriCalendarPref     Boolean  @default(false)

  // Care team (Prompt 14). Replaces the former single assignedTherapistId /
  // responsibleDoctorId scalars — a patient now has any number of therapists
  // and doctors. All assignment read/write funnels through
  // lib/patients/assignment.ts.
  careTeam CareTeamMember[] @relation("CareTeamPatient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CareTeamRole {
  THERAPIST
  DOCTOR
}

/**
 * Care-team membership (Prompt 14). One row per (patient, clinician). A
 * patient may have many therapists and many doctors simultaneously; every
 * member sees the patient exactly as a single assigned clinician did before.
 *
 * `role` is denormalized from the clinician's User.role for index-only
 * filtering ("count my patients as a therapist") — it must always match the
 * referenced user's actual role; the assignment helpers enforce that.
 *
 * This governs patient visibility / responsibility only. The treatment-plan →
 * doctor and appointment → therapist links are separate concerns and are not
 * derived from this table.
 */
model CareTeamMember {
  id          String       @id @default(cuid())
  patientId   String
  clinicianId String
  role        CareTeamRole
  assignedAt  DateTime     @default(now())
  assignedBy  String

  patient   PatientProfile @relation("CareTeamPatient", fields: [patientId], references: [userId], onDelete: Cascade)
  clinician User           @relation("CareTeamClinician", fields: [clinicianId], references: [id], onDelete: Restrict)

  @@unique([patientId, clinicianId])
  @@index([clinicianId, role])
  @@index([patientId])
}

model Specialty {
  id          String   @id @default(cuid())
  nameEn      String   @unique
  nameAr      String   @unique
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserSpecialty[]
}

model UserSpecialty {
  userId      String
  specialtyId String
  assignedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@id([userId, specialtyId])
  @@index([specialtyId])
}

model Room {
  id     String  @id @default(cuid())
  name   String
  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]
}

// ═════════════════════════════════════════════════════════════════════════════
//  Scheduling
// ═════════════════════════════════════════════════════════════════════════════

model Appointment {
  id                   String                @id @default(cuid())
  patientId            String
  // Therapists are a many-to-many via AppointmentTherapist (Prompt 20) — a
  // single session can have two or more therapists at the same time. There is
  // no single `therapistId` column anymore; at least one therapist is required
  // (enforced in the Zod schema + service, not the DB).
  roomId               String?
  startsAt             DateTime
  durationMinutes      Int                   @default(30)
  status               AppointmentStatus     @default(SCHEDULED)
  notes                String?
  cancellationReason   String?
  cancellationCategory CancellationCategory?
  // Free-form notes captured alongside the category at cancel time.
  // The category drives analytics in Prompt 11; this column carries
  // the unstructured context the Secretary wants to keep on the row.
  cancellationNotes    String?
  // Who cancelled + when (Prompt 17) — surfaced in the cancelled-appointments
  // view without an audit-log join.
  cancelledById        String?
  cancelledAt          DateTime?
  // Arrivals (Prompt 18). `checkedInAt` marks the patient as ARRIVED and
  // WAITING — distinct from IN_PROGRESS (in session). The waiting list is
  // derived from these columns + status, not a parallel queue table.
  // `checkedInVia` records whether the kiosk or a staff member checked them in.
  checkedInAt          DateTime?
  checkedInVia         CheckInVia?
  createdById          String
  // Group key for recurring series. Single appointments may leave this null;
  // every occurrence of a series shares the same seriesId. Future features
  // (cancel series, reschedule series) join on this column.
  seriesId             String?

  patient      User          @relation("AppointmentPatient", fields: [patientId], references: [id], onDelete: Restrict)
  therapists   AppointmentTherapist[] @relation("AppointmentTherapists")
  room         Room?         @relation(fields: [roomId], references: [id], onDelete: Restrict)
  createdBy    User          @relation("AppointmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  cancelledBy  User?         @relation("AppointmentCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  // Primary session note + 0..N addenda (Prompt 9 §4.7.3). The partial
  // unique index on SessionNote.appointmentId enforces "at most one
  // primary note per appointment"; addenda share the appointmentId via
  // their parentNoteId chain.
  sessionNotes SessionNote[]

  whatsappMessages WhatsAppMessage[]
  inboxItems       InboxItem[]
  // Prompt 19 — the booking-waitlist entry (if any) this appointment fulfilled.
  // Optional 1:1; set when a waitlisted patient was placed into a freed slot.
  waitlistFulfillment WaitlistEntry? @relation("WaitlistFulfilledAppointment")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, startsAt])
  @@index([status])
  @@index([seriesId])
  @@index([status, cancelledAt])
  @@index([startsAt, checkedInAt])
}

/**
 * Therapists assigned to a single appointment (Prompt 20). A session can need
 * two or more therapists at the same time (e.g. a pediatric session). This is
 * physical session staffing — distinct from the patient's long-term care team
 * (CareTeamMember, Prompt 14). The session's SOAP note is shared (one per
 * appointment); any assigned therapist may write/edit it.
 */
model AppointmentTherapist {
  id            String      @id @default(cuid())
  appointmentId String
  therapistId   String
  appointment   Appointment @relation("AppointmentTherapists", fields: [appointmentId], references: [id], onDelete: Cascade)
  therapist     User        @relation("AppointmentTherapistTherapist", fields: [therapistId], references: [id], onDelete: Restrict)
  createdAt     DateTime    @default(now())

  @@unique([appointmentId, therapistId])
  @@index([therapistId])
  @@index([appointmentId])
}

/**
 * Booking waitlist status (Prompt 19).
 *   WAITING   — active; eligible to be matched when a slot frees.
 *   FULFILLED — placed into a freed slot (links the created appointment).
 *   EXPIRED   — the desired date passed without placement (lazy-flipped on read).
 *   REMOVED   — manually removed by staff.
 */
enum WaitlistStatus {
  WAITING
  FULFILLED
  EXPIRED
  REMOVED
}

/**
 * Booking waitlist entry (Prompt 19) — DISTINCT from the arrivals/check-in
 * waiting list (Prompt 18). When a desired slot is taken, staff park the
 * patient here; when the slot frees (cancel / no-show) the matcher notifies
 * SECRETARY + ADMIN for one-click placement. The system suggests — never
 * auto-books.
 *
 * The desired window is an explicit [windowStart, windowEnd) UTC range (a
 * freed slot matches when its start falls inside it). `desiredDate` is the
 * clinic-local day (UTC midnight) the window sits in, kept for the (date,
 * status) index + management-page grouping.
 */
model WaitlistEntry {
  id          String         @id @default(cuid())
  patientId   String
  desiredDate DateTime
  windowStart DateTime
  windowEnd   DateTime
  // Optional therapist preference. When set, only a freed slot with this
  // therapist matches; when null, any therapist's freed slot matches.
  preferredTherapistId String?
  note                 String?
  status               WaitlistStatus @default(WAITING)

  createdById            String
  fulfilledById          String?
  fulfilledAt            DateTime?
  fulfilledAppointmentId String?   @unique

  patient             User         @relation("WaitlistPatient", fields: [patientId], references: [id], onDelete: Restrict)
  preferredTherapist  User?        @relation("WaitlistPreferredTherapist", fields: [preferredTherapistId], references: [id], onDelete: SetNull)
  createdBy           User         @relation("WaitlistCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  fulfilledBy         User?        @relation("WaitlistFulfilledBy", fields: [fulfilledById], references: [id], onDelete: SetNull)
  fulfilledAppointment Appointment? @relation("WaitlistFulfilledAppointment", fields: [fulfilledAppointmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([desiredDate, status])
  @@index([status])
  @@index([patientId])
}

model TreatmentPlan {
  id                  String     @id @default(cuid())
  patientId           String
  doctorId            String
  assignedTherapistId String
  diagnosisPrimary    String
  diagnosisSecondary  String?
  goalsShortTerm      String
  goalsLongTerm       String
  frequencyPerWeek    Int
  durationWeeks       Int
  status              PlanStatus @default(ACTIVE)
  version             Int        @default(1)
  parentPlanId        String?
  // Free-form notes the Doctor wants the Therapist to read. Optional;
  // distinct from goals so the therapist sees "execution guidance" vs.
  // "clinical objectives" cleanly.
  therapistNotes      String?

  // Proposal lifecycle (Prompt 9 §4.4). Set when a Therapist proposes a
  // change to the active plan via a new row with status=PROPOSED.
  proposalReason String?
  // Set when the Doctor rejects a proposal — visible to the Therapist
  // so they can see why.
  rejectedReason String?
  // Approval audit (set when a PROPOSED row transitions to ACTIVE).
  approvedAt     DateTime?
  approvedById   String?
  approvedBy     User?     @relation("PlanApprovals", fields: [approvedById], references: [id], onDelete: SetNull)

  patient           User            @relation("PlanPatient", fields: [patientId], references: [id], onDelete: Restrict)
  doctor            User            @relation("PlanDoctor", fields: [doctorId], references: [id], onDelete: Restrict)
  assignedTherapist User            @relation("PlanAssignedTherapist", fields: [assignedTherapistId], references: [id], onDelete: Restrict)
  parentPlan        TreatmentPlan?  @relation("PlanVersionChain", fields: [parentPlanId], references: [id], onDelete: Restrict)
  revisions         TreatmentPlan[] @relation("PlanVersionChain")
  exercises         PlanExercise[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Only one ACTIVE plan per patient — enforced by a partial unique index added in
  // the init migration's raw SQL extension (Prisma can't express WHERE on indexes).
  // Prompt 9 adds a second partial unique: at most one PROPOSED plan per patient.
  @@index([patientId, status])
  @@index([assignedTherapistId])
  @@index([doctorId])
  @@index([approvedById])
}

model PlanExercise {
  id              String  @id @default(cuid())
  planId          String
  exerciseId      String
  sets            Int
  reps            Int
  durationSeconds Int
  customNotes     String?
  order           Int

  plan     TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  exercise Exercise      @relation(fields: [exerciseId], references: [id], onDelete: Restrict)

  @@index([planId, order])
}

model Exercise {
  id                   String  @id @default(cuid())
  nameEn               String
  nameAr               String
  descriptionEn        String
  descriptionAr        String
  category             String
  anatomicalRegion     String
  contraindications    String?
  // Default patient-facing instruction. Per-item overrides land on
  // HomeProgramItem.therapistNote.
  defaultInstructionEn String?
  defaultInstructionAr String?
  videoUrl             String?
  videoMimeType        String?
  videoSizeBytes       Int?
  imageUrl             String?
  imageMimeType        String?
  imageSizeBytes       Int?
  version              Int     @default(1)
  createdById          String

  // Version chain (Prompt 10 §4.3.4). Editing creates a new row; the old
  // row gets replacedById set so existing HomeProgramItems continue to
  // reference the version they were assigned, while the library list
  // shows only un-replaced + active rows.
  replacedById String?   @unique
  replacedBy   Exercise? @relation("ExerciseVersions", fields: [replacedById], references: [id], onDelete: SetNull)
  predecessor  Exercise? @relation("ExerciseVersions")
  // Soft delete — keep historical rows visible only through their existing
  // HomeProgramItem references.
  active       Boolean   @default(true)

  createdBy        User              @relation("ExerciseCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  planExercises    PlanExercise[]
  homeProgramItems HomeProgramItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([anatomicalRegion])
  @@index([active, replacedById])
}

model SessionNote {
  id            String  @id @default(cuid())
  // appointmentId is unique for *primary* notes only — addenda share the
  // appointment with their parent. Enforced by a partial unique index in
  // the Prompt 9 migration: UNIQUE (appointmentId) WHERE parentNoteId IS NULL.
  appointmentId String
  patientId     String
  therapistId   String
  subjective    String
  objective     String
  assessment    String
  plan          String
  painScore     Int?
  measurements  Json?
  // Addendum chain (Prompt 9 §4.7.3). When non-null, this row is an
  // amendment that points at its parent primary note. The 24-hour
  // immutability rule applies to the row itself, not the chain.
  parentNoteId  String?

  appointment Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Restrict)
  patient     User          @relation("NotePatient", fields: [patientId], references: [id], onDelete: Restrict)
  therapist   User          @relation("NoteTherapist", fields: [therapistId], references: [id], onDelete: Restrict)
  parentNote  SessionNote?  @relation("SessionNoteAddenda", fields: [parentNoteId], references: [id], onDelete: Restrict)
  addenda     SessionNote[] @relation("SessionNoteAddenda")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt])
  @@index([therapistId, createdAt])
  @@index([appointmentId])
  @@index([parentNoteId])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Home program
// ═════════════════════════════════════════════════════════════════════════════

model HomeProgramItem {
  id              String  @id @default(cuid())
  patientId       String
  exerciseId      String
  // Days the exercise is scheduled. 0 = Sunday, 6 = Saturday. The
  // home_program_items_days_of_week_check constraint in the Prompt 10
  // migration enforces length 1-7, values 0-6, and uniqueness.
  daysOfWeek      Int[]
  // Time-of-day as "HH:MM" — see file header note. Recurring local-time concept.
  scheduledTime   String
  durationMinutes Int
  setsReps        String?
  therapistNote   String?
  active          Boolean @default(true)
  // BullMQ repeat-job key returned by Queue.add(). Stored here so the
  // update / delete paths can call removeRepeatableByKey() without
  // re-deriving the cron pattern.
  reminderJobKey  String?

  patient     User                    @relation("HomeProgramPatient", fields: [patientId], references: [id], onDelete: Restrict)
  exercise    Exercise                @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  completions HomeProgramCompletion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, active])
  @@index([exerciseId])
}

model HomeProgramCompletion {
  id            String    @id @default(cuid())
  itemId        String
  scheduledDate DateTime  @db.Date
  completedAt   DateTime?
  painScore     Int?

  item HomeProgramItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([itemId, scheduledDate])
  @@index([itemId, scheduledDate])
}

/**
 * Per-patient home-program approval state (Prompt 16). One row per patient
 * governs whether the patient (portal + WhatsApp reminders) may see the
 * program. The live HomeProgramItem rows are the working draft the clinicians
 * edit; `approvedSnapshot` is the frozen approved content the patient keeps
 * seeing while a therapist's revision is PENDING_APPROVAL.
 *
 * `remindersEnabled` is a delivery preference (not clinical content) — toggling
 * it is audited but does NOT change the approval status. Reminders fire only
 * when status = APPROVED AND remindersEnabled = true.
 */
model HomeProgramApproval {
  patientId        String            @id
  status           HomeProgramStatus @default(DRAFT)
  remindersEnabled Boolean           @default(true)

  submittedById String?
  submittedAt   DateTime?
  reviewedById  String?
  reviewedAt    DateTime?
  changesComment String?

  // Denormalized HomeProgramItemRow[] of the last approved content.
  approvedSnapshot Json?
  approvedAt       DateTime?

  patient     User  @relation("HomeProgramApprovalPatient", fields: [patientId], references: [id], onDelete: Cascade)
  submittedBy User? @relation("HomeProgramSubmittedBy", fields: [submittedById], references: [id], onDelete: SetNull)
  reviewedBy  User? @relation("HomeProgramReviewedBy", fields: [reviewedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Leave
// ═════════════════════════════════════════════════════════════════════════════

model Leave {
  id           String      @id @default(cuid())
  userId       String
  startDate    DateTime    @db.Date
  endDate      DateTime    @db.Date
  leaveType    LeaveType
  status       LeaveStatus @default(PENDING)
  reason       String?
  approvedById String?

  user       User  @relation("LeaveUser", fields: [userId], references: [id], onDelete: Restrict)
  approvedBy User? @relation("LeaveApprovedBy", fields: [approvedById], references: [id], onDelete: Restrict)

  inboxItems InboxItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startDate])
  @@index([status])
}

// ═════════════════════════════════════════════════════════════════════════════
//  WhatsApp
// ═════════════════════════════════════════════════════════════════════════════

model WhatsAppTemplate {
  id             String             @id @default(cuid())
  // Logical template name — the canonical identifier the application uses
  // when calling whatsapp.sendTemplate(). Stable across providers; do not
  // change once a template is referenced in code. Provider-specific names
  // (Meta template name, Twilio ContentSid) live in their own columns.
  name           String
  language       LanguagePref
  category       WaTemplateCategory
  contentPreview String
  active         Boolean            @default(true)

  // Meta Cloud API metadata. Template names follow Meta's naming rules
  // (lowercase, underscores, ≤512 chars) and aren't editable after
  // approval. Status is maintained by the Admin manually for v1; future
  // versions can poll Meta's template management API.
  metaTemplateName   String?
  metaApprovalStatus WaTemplateApprovalStatus @default(NOT_SUBMITTED)
  metaApprovedAt     DateTime?

  // Twilio Content API metadata. ContentSids look like `HXxxxx…` and are
  // opaque; we record them here and use them at send-time.
  twilioContentSid String?
  twilioApproved   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages WhatsAppMessage[]

  @@unique([name, language])
}

model WhatsAppMessage {
  id                String             @id @default(cuid())
  templateId        String?
  recipientId       String?
  recipientPhone    String
  parameters        Json               @default("{}")
  direction         WaMessageDirection
  status            WaMessageStatus    @default(QUEUED)
  // Provider-side message identifier (Twilio SID `SM…` / `MM…` or Meta
  // `wamid.…`). Used to correlate inbound webhook events back to the row
  // and to deduplicate redelivered webhooks.
  providerMessageId String?
  body              String
  // Free-form reason captured on FAILED status — surfaced in the Admin
  // message log and the patient profile reachability section.
  failureReason     String?
  // Inbound intent classification (CONFIRM / RESCHEDULE_REQUEST / …) or
  // null for outbound. Computed by lib/whatsapp/inbound/parser.ts.
  intent            WaInboundIntent?
  // Linked appointment when the message concerns an appointment — set on
  // outbound (reminder, confirmation, rescheduled, cancelled) and on
  // inbound replies matched to the most recent outbound within 24h.
  appointmentId     String?
  // Number of resends issued from /admin/whatsapp/messages — capped at 3
  // (see lib/whatsapp/resend.ts) to defend against feedback loops.
  resendCount       Int                @default(0)
  sentAt            DateTime           @default(now())
  deliveredAt       DateTime?
  readAt            DateTime?

  template    WhatsAppTemplate? @relation(fields: [templateId], references: [id], onDelete: Restrict)
  recipient   User?             @relation("WhatsAppRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  appointment Appointment?      @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  inboxItems InboxItem[] @relation("InboxItemMessage")

  createdAt DateTime @default(now())

  @@index([recipientPhone, sentAt(sort: Desc)])
  @@index([status])
  @@index([providerMessageId])
  @@index([appointmentId])
}

// ─────────────────────────────────────────────────────────────────────────────
//  Secretary inbox — action items raised by inbound WhatsApp parsing and by
//  outbound delivery failures. The Secretary works the inbox to triage
//  reschedule requests, fix unreachable phone numbers, and acknowledge
//  unstructured patient replies. See Prompt 8 §4.7 / §4.8.
// ─────────────────────────────────────────────────────────────────────────────

model InboxItem {
  id            String        @id @default(cuid())
  type          InboxItemType
  patientId     String?
  appointmentId String?
  messageId     String?
  // Optional reference to the approved leave that caused the conflict.
  // Used by LEAVE_CONFLICT items so the Secretary can see "this clash
  // came from <Therapist> being on leave <date range>" without joining
  // through the appointment.
  leaveId       String?
  // Free-form note captured at creation time (e.g., the failure reason or
  // the inbound body preview). Avoids forcing the Secretary to open the
  // related row to triage.
  note          String?

  resolvedAt   DateTime?
  resolvedById String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient     User?            @relation("InboxItemPatient", fields: [patientId], references: [id], onDelete: SetNull)
  appointment Appointment?     @relation(fields: [appointmentId], references: [id], onDelete: SetNull)
  message     WhatsAppMessage? @relation("InboxItemMessage", fields: [messageId], references: [id], onDelete: SetNull)
  resolvedBy  User?            @relation("InboxItemResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  leave       Leave?           @relation(fields: [leaveId], references: [id], onDelete: SetNull)

  // Resolved items stay in the table for audit; the inbox queries filter
  // on `resolvedAt IS NULL`. The compound index keeps that lookup cheap.
  @@index([resolvedAt, createdAt(sort: Desc)])
  @@index([patientId, createdAt(sort: Desc)])
  @@index([leaveId])
}

// ─────────────────────────────────────────────────────────────────────────────
//  Clinical workflows — notifications, day reports, doctor reviews (Prompt 9).
//
//  Notifications: a generic in-app delivery surface. Clinical events
//  (plan assigned, proposal received, day report submitted, …) fan out
//  one row per recipient. Patient-facing channels stay separate; nothing
//  here goes to WhatsApp in v1.
//
//  DayReport: one row per therapist per day. Holds the therapist's
//  end-of-day summary plus per-patient notes; the doctor's weekly review
//  page aggregates these grouped by patient.
//
//  DoctorReview: doctor's per-patient clinical commentary written during
//  the weekly review pass. Immutable once submitted; a second row for the
//  same (doctor, patient, weekStarting) is allowed as an amendment.
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id                String           @id @default(cuid())
  recipientId       String
  recipient         User             @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  type              NotificationType
  // i18n keys — the bell renderer reads `notifications.types.{type}.title`
  // and `.body` and interpolates `params` into the template.
  titleKey          String
  bodyKey           String
  // {paramKey: value} pairs the renderer substitutes into the localized
  // text. Strongly recommend keeping the param set narrow per type so
  // the templates don't drift.
  params            Json             @default("{}")
  linkPath          String?
  relatedEntityType String?
  relatedEntityId   String?
  readAt            DateTime?

  createdAt DateTime @default(now())

  // Compound index supporting "unread count for me" + "my latest
  // notifications", which are the two reads we do on every page load.
  @@index([recipientId, readAt, createdAt(sort: Desc)])
}

model DayReport {
  id             String   @id @default(cuid())
  therapistId    String
  therapist      User     @relation("TherapistDayReports", fields: [therapistId], references: [id], onDelete: Restrict)
  // Date the report covers. Stored as @db.Date so date-only comparisons
  // are timezone-stable (no midnight-rollover bugs across DST).
  date           DateTime @db.Date
  overallSummary String
  // [{patientId, appointmentId, note}] — keyed by patientId for the
  // doctor's weekly grouping. Schema-validated at the action boundary.
  patientEntries Json
  submittedAt    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Upsert key — submitting twice on the same date overwrites rather
  // than duplicates.
  @@unique([therapistId, date])
  @@index([date])
}

model DoctorReview {
  id           String   @id @default(cuid())
  doctorId     String
  doctor       User     @relation("DoctorReviews", fields: [doctorId], references: [id], onDelete: Restrict)
  patientId    String
  patient      User     @relation("PatientDoctorReviews", fields: [patientId], references: [id], onDelete: Restrict)
  // Start of the ISO week the review covers (Monday by convention).
  weekStarting DateTime @db.Date
  comment      String

  createdAt DateTime @default(now())

  @@index([patientId, createdAt(sort: Desc)])
  @@index([doctorId, weekStarting])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Audit log
// ═════════════════════════════════════════════════════════════════════════════

model AuditLog {
  id         String      @id @default(cuid())
  actorId    String
  entityType String
  entityId   String
  action     AuditAction
  before     Json?
  after      Json?

  // When the action was performed during an Admin impersonation session,
  // `actorId` is the real Admin and `impersonatedUserId` is the user the
  // Admin was acting as. Null when the actor was acting as themselves.
  impersonatedUserId String?

  actor            User  @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)
  impersonatedUser User? @relation("AuditImpersonated", fields: [impersonatedUserId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@index([impersonatedUserId, createdAt(sort: Desc)])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Intake assessment — parent + adult/pediatric detail tables + custom questions
// ═════════════════════════════════════════════════════════════════════════════
//
// Why split into parent + detail tables rather than one JSONB blob?
// See docs/db/schema.md Decisions log. Short version: pain severity distributions,
// referral-source breakdowns, and symptom-duration analytics all rely on the
// fields being typed columns. A JSONB blob loses every aggregation.

model IntakeAssessment {
  id                    String       @id @default(cuid())
  patientId             String
  type                  IntakeType
  assessedAt            DateTime     @default(now())
  assessedById          String
  status                IntakeStatus @default(IN_PROGRESS)
  reviewedByClinicianId String?
  reviewedAt            DateTime?

  patient             User                 @relation("IntakePatient", fields: [patientId], references: [id], onDelete: Restrict)
  assessedBy          User                 @relation("IntakeAssessor", fields: [assessedById], references: [id], onDelete: Restrict)
  reviewedByClinician User?                @relation("IntakeReviewer", fields: [reviewedByClinicianId], references: [id], onDelete: Restrict)
  adultData           AdultIntakeData?
  pediatricData       PediatricIntakeData?
  customAnswers       IntakeCustomAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // No unique on patientId — a patient may have multiple intakes over time
  // (reassessment after a new injury, follow-up, etc.).
  @@index([patientId, assessedAt(sort: Desc)])
  @@index([status])
  @@index([type])
}

model AdultIntakeData {
  intakeId String           @id
  intake   IntakeAssessment @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  physicalActivityLevel        PhysicalActivityLevel
  medicalDiagnosis             String?
  primaryComplaint             String
  painTiming                   PainTiming
  symptomDuration              SymptomDuration
  painSeverity                 PainSeverity
  painAggravatingFactors       String?
  painRelievingFactors         String?
  painStability                PainStability
  currentMedicationsForProblem String?
  otherMedications             String?
  conditions                   Comorbidity[]
  otherConditions              String?
  previousFractures            String?
  previousSurgeries            String?
  previousPtExperience         String?
  referralSource               ReferralSource

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PediatricIntakeData {
  intakeId String           @id
  intake   IntakeAssessment @relation(fields: [intakeId], references: [id], onDelete: Cascade)

  numberOfSiblings Int
  birthOrder       Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IntakeCustomQuestion {
  id           String                  @id @default(cuid())
  nameEn       String
  nameAr       String
  type         CustomQuestionType
  // options shape: [{ valueEn: string, valueAr: string }] — only used for
  // SINGLE_SELECT and MULTI_SELECT. Null/empty for other types.
  options      Json?
  appliesTo    CustomQuestionAppliesTo
  required     Boolean                 @default(false)
  displayOrder Int                     @default(0)
  active       Boolean                 @default(true)
  createdById  String

  createdBy User                 @relation("CustomQuestionCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  answers   IntakeCustomAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([appliesTo, active, displayOrder])
}

model IntakeCustomAnswer {
  id           String  @id @default(cuid())
  intakeId     String
  questionId   String
  // For TEXT / TEXTAREA / NUMBER / DATE.
  value        String?
  // For SINGLE_SELECT / MULTI_SELECT — array of selected option values.
  // Stored as JSON so renaming an option later does not corrupt historical answers.
  valueOptions Json?

  intake   IntakeAssessment     @relation(fields: [intakeId], references: [id], onDelete: Cascade)
  question IntakeCustomQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([intakeId, questionId])
  @@index([questionId])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Pediatric assessment (Prompt 21) — fixed core + clinic-wide custom fields
// ═════════════════════════════════════════════════════════════════════════════

enum PediatricCustomFieldType {
  SINGLE_SELECT
  MULTI_SELECT
  TEXT
  LONG_TEXT
  SCORE_0_3
  NUMBER
  BOOLEAN
}

/**
 * A structured pediatric physiotherapy assessment (Prompt 21). Replaces
 * Dr. Sahar's external Google Forms. `coreData` holds the fixed 65-field core
 * (validated by lib/pediatric-assessment/coreSchema, with `schemaVersion`);
 * `customData` is a map of customFieldId → value for the clinic-wide custom
 * fields. Multiple rows per patient, newest first. DOCTOR/ADMIN write,
 * THERAPIST reads. Every create/edit is audited.
 */
model PediatricAssessment {
  id          String   @id @default(cuid())
  patientId   String
  createdById String
  updatedById String?
  coreData    Json
  customData  Json     @default("{}")

  patient   User  @relation("PedAssessmentPatient", fields: [patientId], references: [id], onDelete: Restrict)
  createdBy User  @relation("PedAssessmentCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  updatedBy User? @relation("PedAssessmentUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([patientId, createdAt(sort: Desc)])
}

/**
 * Clinic-wide custom field definitions for the pediatric assessment (Prompt 21
 * §2/§3). A field Dr. Sahar adds appears on EVERY patient's assessment going
 * forward (clinic-wide, not per-patient — flag if per-patient is ever wanted).
 * Removal is soft (active=false) so past assessments that stored a value still
 * render it. Managed by DOCTOR/ADMIN.
 */
model PediatricCustomField {
  id          String                   @id @default(cuid())
  labelEn     String
  labelAr     String
  type        PediatricCustomFieldType
  // For SINGLE_SELECT / MULTI_SELECT: [{ value, labelEn, labelAr }]. Null otherwise.
  options     Json?
  section     String?
  order       Int                      @default(0)
  active       Boolean                 @default(true)
  createdById String

  createdBy User @relation("PedCustomFieldCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, order])
}

// ═════════════════════════════════════════════════════════════════════════════
//  Clinic settings — singleton (Prompt 5 §4.3 / spec FR-ADM-3)
// ═════════════════════════════════════════════════════════════════════════════

model ClinicSettings {
  // Hardcoded singleton id. The seed upserts `id = "default"`; the UI
  // never exposes this string.
  id String @id @default("default")

  nameEn    String
  nameAr    String
  phone     String
  addressEn String
  addressAr String
  timezone  String @default("Asia/Amman")

  defaultAppointmentDuration   Int @default(30)
  // Reminder timing (Prompt 17): one message `offset` minutes before the
  // appointment (default 24h = 1440), clamped to the [windowStart, windowEnd]
  // clinic-local window (HH:MM) so reminders never fire outside working hours.
  defaultReminderOffsetMinutes Int    @default(1440)
  reminderWindowStart          String @default("08:00")
  reminderWindowEnd            String @default("18:00")

  // Arrivals (Prompt 18). `currentDelayMinutes` is the manual "your turn in
  // ~X minutes" value the kiosk shows — adjusted live by the secretary, no
  // queue-position math. The two tokens gate the public kiosk + lobby-display
  // routes (separate trust zones); null = that surface is disabled.
  currentDelayMinutes Int     @default(10)
  kioskToken          String? @unique
  displayToken        String? @unique

  // { sun: { open: "09:00", close: "18:00", closed: false }, mon: ..., fri: { closed: true } }
  businessHours Json

  defaultLanguage LanguagePref @default(AR)

  // [{ id, nameEn, nameAr, defaultDurationMinutes }]
  serviceTypes Json

  hijriDefault Boolean @default(false)

  // Whether patients can see clinical content (treatment plan, session
  // notes) in their own file. Default OFF per Prompt 9 §3 — many PT
  // practices share openly, others don't. A small UI toggle on the
  // Clinic Settings page from Prompt 5 covers this.
  patientCanViewClinicalNotes Boolean @default(false)

  updatedAt   DateTime @updatedAt
  updatedById String?
  updatedBy   User?    @relation("ClinicSettingsUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
}
