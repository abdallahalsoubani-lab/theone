  PLAN_PROPOSAL_RECEIVED
  PLAN_PROPOSAL_APPROVED
  PLAN_PROPOSAL_REJECTED
  PLAN_PAUSED
  PLAN_DISCONTINUED
  DAY_REPORT_SUBMITTED
  DOCTOR_REVIEW_ADDED
  APPOINTMENT_RESCHEDULE_REQUEST
  LOW_COMPLIANCE
  APPOINTMENT_THERAPIST_ASSIGNED
  APPOINTMENT_THERAPIST_REMOVED
  LEAVE_REQUESTED
  LEAVE_APPROVED
  LEAVE_REJECTED
  HOME_PROGRAM_SUBMITTED
  HOME_PROGRAM_APPROVED
  HOME_PROGRAM_CHANGES_REQUESTED
  // Prompt 19 — a slot a waitlisted patient was waiting for just freed up
  // (cancellation / no-show). Targets SECRETARY + ADMIN; links to the
