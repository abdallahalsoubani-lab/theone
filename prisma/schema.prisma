enum InboxItemType {
  INBOUND_RESCHEDULE_REQUEST
  INBOUND_CANCEL_REQUEST
  INBOUND_UNKNOWN
  OUTBOUND_DELIVERY_FAILED
  LEAVE_CONFLICT
