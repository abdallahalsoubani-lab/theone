// Theone.pt — Prisma schema
//
// Owned by Prompt 2 (Database Schema). Subsequent prompts MAY add fields/models, but
// MUST NOT silently re-shape existing entities — any change goes through a reviewed
// migration. See docs/db/schema.md for the ERD and decisions log.
//
// Conventions baked in here:
//   - id: String @id @default(cuid())
//   - timestamps: createdAt @default(now()), updatedAt @updatedAt
//   - soft delete: deletedAt DateTime? on User; clinical rows never soft-delete
//   - foreign keys: onDelete: Restrict by default for clinical data (no accidental
//     cascades destroying patient history). Cascade is reserved for tightly-coupled
//     1:1 detail rows (AdultIntakeData, PediatricIntakeData, IntakeCustomAnswer).
//   - times of day: stored as "HH:MM" strings; an exercise at 7pm is a recurring
//     local-time concept, not a single moment.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
//  Enums
// ═════════════════════════════════════════════════════════════════════════════

enum UserRole {
  PATIENT
  SECRETARY
  DOCTOR
  THERAPIST
  ADMIN
}

enum LanguagePref {
  EN
  AR
}

enum Gender {
  MALE
  FEMALE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

// How a patient was checked in / marked as arrived (Prompt 18 arrivals).
enum CheckInVia {
  KIOSK
  STAFF
}

enum CancellationCategory {
  PATIENT_REQUEST
  PATIENT_NO_SHOW
  PATIENT_ILLNESS
  PATIENT_TRAVEL
  CLINIC_RESCHEDULING
  THERAPIST_UNAVAILABLE
  WEATHER
  INSURANCE_ISSUE
  OTHER
}

enum PlanStatus {
  ACTIVE
  PROPOSED
  REJECTED
  SUPERSEDED
  PAUSED
  COMPLETED
  DISCONTINUED
}

enum NotificationType {
