# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Theone.pt"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Database (Prompt 2) ──────────────────────────────────────────────────────
# POSTGRES_* are consumed by docker-compose; DATABASE_URL is consumed by Prisma.
POSTGRES_USER="theone"
POSTGRES_PASSWORD="dev_password_change_me"
POSTGRES_DB="theone_dev"
DATABASE_URL="postgresql://theone:dev_password_change_me@localhost:5432/theone_dev"

# ─── Redis (Prompt 8) ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Storage — MinIO locally, S3 in production (Prompt 6/7) ───────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="theone-uploads"
S3_ACCESS_KEY_ID="minio_admin"
S3_SECRET_ACCESS_KEY="minio_admin_change_me"
# MINIO_ROOT_* are consumed only by the MinIO container; in prod use AWS IAM instead.
MINIO_ROOT_USER="minio_admin"
MINIO_ROOT_PASSWORD="minio_admin_change_me"

# ─── WhatsApp (filled in Prompt 8) ────────────────────────────────────────────
# WHATSAPP_PROVIDER selects which provider implementation lib/whatsapp resolves at runtime.
WHATSAPP_PROVIDER="twilio"  # twilio | meta
# Twilio sandbox (development + CI)
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_WHATSAPP_FROM=""
# Meta Cloud API (production)
# META_WHATSAPP_PHONE_ID=""
# META_WHATSAPP_TOKEN=""
# META_WHATSAPP_VERIFY_TOKEN=""

# ─── Auth (filled in Prompt 4) ────────────────────────────────────────────────
# AUTH_SECRET: openssl rand -base64 32
# AUTH_SECRET=""
# AUTH_URL="http://localhost:3000"
