# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="Theone.pt"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Database (Prompt 2) ──────────────────────────────────────────────────────
# POSTGRES_* are consumed by docker-compose; DATABASE_URL is consumed by Prisma.
POSTGRES_USER="theone"
POSTGRES_PASSWORD="dev_password_change_me"
POSTGRES_DB="theone_dev"
DATABASE_URL="postgresql://theone:dev_password_change_me@localhost:5432/theone_dev"

# ─── Redis (Prompt 8) ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Storage — MinIO locally, S3 in production (Prompt 6/7) ───────────────────
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="theone-uploads"
S3_ACCESS_KEY_ID="minio_admin"
S3_SECRET_ACCESS_KEY="minio_admin_change_me"
# MINIO_ROOT_* are consumed only by the MinIO container; in prod use AWS IAM instead.
MINIO_ROOT_USER="minio_admin"
MINIO_ROOT_PASSWORD="minio_admin_change_me"

# Public base URL the browser hits to render uploaded images / videos.
# Defaults to `${S3_ENDPOINT}/${S3_BUCKET}` when unset (fine for local MinIO).
# Production sets this to a CDN (CloudFront / Cloudflare) so traffic doesn't
# terminate at S3 directly. Read via `env.S3_PUBLIC_BASE_URL` from lib/env.ts.
# S3_PUBLIC_BASE_URL="https://cdn.theone.pt"

# ─── Home program reminders (Prompt 10) ───────────────────────────────────────
# Minutes ahead of each scheduled exercise that the WhatsApp reminder fires.
# Patient-facing copy assumes 30; change with care. Default applied when unset.
HOME_REMINDER_OFFSET_MINUTES="30"

# ─── WhatsApp (Prompt 8) ──────────────────────────────────────────────────────
# WHATSAPP_PROVIDER selects the active provider. `console` logs to stderr (dev);
# `meta` activates the Meta Cloud API. See docs/whatsapp/setup-meta.md.
WHATSAPP_PROVIDER="console"  # console | meta

# Meta Cloud API (production). APP_SECRET is the WhatsApp Business App's
# app secret used to sign inbound webhook bodies (x-hub-signature-256).
# META_WHATSAPP_PHONE_NUMBER_ID=""
# META_WHATSAPP_BUSINESS_ACCOUNT_ID=""
# META_WHATSAPP_ACCESS_TOKEN=""
# META_WHATSAPP_VERIFY_TOKEN=""
# META_WHATSAPP_APP_SECRET=""

# ─── Auth (Prompt 4) ──────────────────────────────────────────────────────────
# AUTH_SECRET signs JWT session cookies. Generate with: openssl rand -base64 32
# In production, set per-environment via your secret manager — never commit a real value.
AUTH_SECRET="dev_only_change_me_at_least_32_chars_long_dev_only_change_me_at_least_32_chars_long"
AUTH_URL="http://localhost:3000"
# AUTH_TRUST_HOST is required on every host that is not localhost (Vercel, custom domains).
AUTH_TRUST_HOST="true"

# OTP delivery sender — selected by env. Prompt 8 implements the WhatsApp side;
# in dev we log to the server console so QA can read the code without a phone.
OTP_SENDER="console"  # console | whatsapp
